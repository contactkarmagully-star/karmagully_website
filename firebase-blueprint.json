{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An anime metal poster product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "isCOD": { "type": "boolean" },
        "stock": { "type": "number" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "imageUrl", "category"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrator user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "number" }
      },
      "required": ["email"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerInfo": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "totalAmount": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["COD", "Online"] },
        "orderStatus": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered"] },
        "address": { "type": "object" },
        "createdAt": { "type": "number" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "expiryDate": { "type": "string" }
      },
      "required": ["code", "discountType", "discountValue", "isActive"]
    },
    "Settings": {
      "title": "Settings",
      "description": "App configuration",
      "type": "object",
      "properties": {
        "announcement": { "type": "string" },
        "showAnnouncement": { "type": "boolean" },
        "flashSale": {
          "type": "object",
          "properties": {
            "isActive": { "type": "boolean" },
            "title": { "type": "string" },
            "endTime": { "type": "string" },
            "discountText": { "type": "string" }
          }
        }
      }
    },
    "Page": {
      "title": "Page",
      "description": "A custom CMS page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image", "video"] },
              "value": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "slug"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of metal posters"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store orders"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Authorized admin users"
    },
    "/coupons/{code}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    },
    "/settings/{id}": {
      "schema": "Settings",
      "description": "Global application settings"
    },
    "/pages/{slug}": {
      "schema": "Page",
      "description": "Custom dynamic pages"
    }
  }
}
